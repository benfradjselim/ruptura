    <tr><td>Mean X</td><td>μₓ⁽ⁿ⁺¹⁾ = μₓ⁽ⁿ⁾ + (xₙ₊₁ - μₓ⁽ⁿ⁾) / (n+1)</td></tr>
    <tr><td>Mean Y</td><td>μᵧ⁽ⁿ⁺¹⁾ = μᵧ⁽ⁿ⁾ + (yₙ₊₁ - μᵧ⁽ⁿ⁾) / (n+1)</td></tr>
